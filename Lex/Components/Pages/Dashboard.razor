@page "/dashboard"
@attribute [Authorize]
@using Lex.Components.Auth
@using Lex.Domain.DTOs
@using Lex.Domain.Interfaces
@using Microsoft.AspNetCore.Authorization
@inject IDashboardService DashboardService
@inject UserContext UserContext
@inject NavigationManager NavigationManager

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">

    <div class="d-flex align-center justify-space-between flex-wrap gap-2 mb-6">
        <div>
            <MudText Typo="Typo.h3">Дашборд</MudText>
            <MudText Typo="Typo.body2" Class="text-muted">
                @(_scope == DashboardScope.Personal ? "Ваша активность" : _orgDashboard?.OrganizationName)
            </MudText>
        </div>

        @if (_orgDashboard is not null)
        {
            <MudButtonGroup Variant="Variant.Outlined" Color="Color.Primary">
                <MudButton Variant="@(_scope == DashboardScope.Personal ? Variant.Filled : Variant.Outlined)"
                           OnClick="@(() => SetScope(DashboardScope.Personal))">
                    Личный
                </MudButton>
                <MudButton Variant="@(_scope == DashboardScope.Organization ? Variant.Filled : Variant.Outlined)"
                           OnClick="@(() => SetScope(DashboardScope.Organization))">
                    Организация
                </MudButton>
            </MudButtonGroup>
        }
    </div>

    @if (_isLoading)
    {
        <MudGrid>
            @for (int i = 0; i < 4; i++)
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudSkeleton Width="100%" Height="120px" Class="rounded-lg" />
                </MudItem>
            }
        </MudGrid>
    }
    else if (_scope == DashboardScope.Personal)
    {
        @RenderStats(_personalDashboard!.Checklists, _personalDashboard.Documents)
        @RenderActivity(_personalDashboard.RecentChecklists, _personalDashboard.RecentDocuments, showOwner: false)
    }
    else if (_orgDashboard is not null)
    {
        <MudGrid Class="mb-4">
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 rounded-lg stat-card" Elevation="0">
                    <MudText Typo="Typo.caption" Class="text-muted">Сотрудников</MudText>
                    <MudText Typo="Typo.h4">@_orgDashboard.StaffCount</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @RenderStats(_orgDashboard.Checklists, _orgDashboard.Documents)

        @if (_orgDashboard.TopContributors.Any())
        {
            <MudText Typo="Typo.h6" Class="mb-2 mt-2">Самые активные сотрудники</MudText>
            <MudCard Elevation="1" Class="section-card mb-6">
                <MudCardContent>
                    @foreach (var person in _orgDashboard.TopContributors)
                    {
                        <div class="d-flex align-center gap-3 py-2">
                            <MudAvatar Color="Color.Secondary" Size="Size.Small">
                                @string.Concat(person.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(p => char.ToUpper(p[0])))
                            </MudAvatar>
                            <MudText Typo="Typo.body1" Class="flex-grow-1">@person.FullName</MudText>
                            <MudText Typo="Typo.caption" Class="text-muted">
                                @person.ChecklistsStarted чек-листов · @person.DocumentsCreated документов
                            </MudText>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        }

        @RenderActivity(_orgDashboard.RecentChecklists, _orgDashboard.RecentDocuments, showOwner: true)
    }

    <MudText Typo="Typo.h6" Class="mb-2 mt-2">Активность за год</MudText>

    @if (_isActivityLoading)
    {
        <MudSkeleton Width="100%" Height="140px" Class="rounded-lg mb-2" />
    }
    else if (_activity is not null)
    {
        <MudPaper Class="pa-4 rounded-lg mb-2" Elevation="0">
            <div class="d-flex justify-space-between align-center mb-3 flex-wrap gap-2">
                <MudText Typo="Typo.body2" Class="text-muted">
                    @_activity.TotalEventsInRange событий за последний год
                </MudText>
                @if (_activity.CurrentStreakDays > 0)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text" Icon="@Icons.Material.Filled.LocalFireDepartment">
                        Серия: @_activity.CurrentStreakDays дн.
                    </MudChip>
                }
            </div>

            <div class="heatmap-scroll">
                <div class="heatmap-grid">
                    @foreach (var week in _heatmapWeeks)
                    {
                        <div class="heatmap-week">
                            @foreach (var day in week)
                            {
                                @if (day is null)
                                {
                                    <div class="heatmap-cell heatmap-cell-empty"></div>
                                }
                                else
                                {
                                    <MudTooltip Text="@GetHeatmapTooltip(day)">
                                        <div class="heatmap-cell @GetHeatmapLevelClass(day.Count)"></div>
                                    </MudTooltip>
                                }
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="d-flex align-center justify-end gap-1 mt-2">
                <MudText Typo="Typo.caption" Class="text-muted mr-1">Меньше</MudText>
                @for (int level = 0; level <= 4; level++)
                {
                    <div class="heatmap-cell heatmap-legend-cell heatmap-level-@level"></div>
                }
                <MudText Typo="Typo.caption" Class="text-muted ml-1">Больше</MudText>
            </div>
        </MudPaper>

        <MudText Typo="Typo.h6" Class="mb-2 mt-4">Последние события</MudText>
        @if (!_activity.RecentEvents.Any())
        {
            <MudText Typo="Typo.body2" Class="text-muted mb-6">Пока нет активности</MudText>
        }
        else
        {
            <MudTimeline TimelinePosition="TimelinePosition.Start" Class="mb-6">
                @foreach (var evt in _activity.RecentEvents)
                {
                    <MudTimelineItem Size="Size.Small" Color="@GetEventColor(evt.Type)" Icon="@GetEventIcon(evt.Type)">
                        <ItemContent>
                            <div class="activity-timeline-row @(evt.NavigateUrl is not null ? "activity-clickable" : "")"
                                 @onclick="@(() => NavigateIfPossible(evt.NavigateUrl))">
                                <MudText Typo="Typo.body2">@evt.Title</MudText>
                                <div class="d-flex align-center gap-2 flex-wrap mt-1">
                                    @if (!string.IsNullOrWhiteSpace(evt.SubTitle))
                                    {
                                        <MudText Typo="Typo.caption" Class="text-muted">@evt.SubTitle</MudText>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(evt.ActorName))
                                    {
                                        <MudText Typo="Typo.caption" Class="text-muted">· @evt.ActorName</MudText>
                                    }
                                    <MudText Typo="Typo.caption" Class="text-muted">
                                        · @evt.OccurredAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                    </MudText>
                                </div>
                            </div>
                        </ItemContent>
                    </MudTimelineItem>
                }
            </MudTimeline>
        }
    }
    <MudText Typo="Typo.caption" Class="text-muted mb-6">
        Демо-заглушка — реальная активность появится здесь позже
    </MudText>

</MudContainer>

@code {
    private enum DashboardScope { Personal, Organization }
    private DashboardScope _scope = DashboardScope.Personal;
    
    private ActivityDashboardDto? _activity;
    private bool _isActivityLoading = true;
    private List<List<ActivityHeatmapDayDto?>> _heatmapWeeks = new();

    private PersonalDashboardDto? _personalDashboard;
    private OrganizationDashboardDto? _orgDashboard;
    private bool _isLoading = true;
    private Guid? _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        _currentUserId = Guid.TryParse(UserContext.CurrentUser?.UserId, out var uid) ? uid : null;
        if (!_currentUserId.HasValue)
        {
            _isLoading = false;
            _isActivityLoading = false;
            return;
        }

        _personalDashboard = await DashboardService.GetPersonalDashboardAsync(_currentUserId.Value);
        _orgDashboard = await DashboardService.GetOrganizationDashboardAsync(_currentUserId.Value);
        _isLoading = false;

        await LoadActivity();
    }

    private RenderFragment RenderStats(ChecklistDashboardStatsDto checklists, DocumentDashboardStatsDto documents) => __builder =>
    {
        <MudGrid Class="mb-6">
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4 rounded-lg stat-card h-100" Elevation="0">
                    <MudText Typo="Typo.subtitle2" Class="mb-3 d-flex align-center gap-1">
                        <MudIcon Icon="@Icons.Material.Filled.Checklist" Size="Size.Small" /> Чек-листы
                    </MudText>
                    <div class="d-flex align-center gap-4">
                        <MudProgressCircular Value="@checklists.CompletionRatePercent" Size="Size.Large" Color="Color.Primary" StrokeWidth="6">
                            <MudText Typo="Typo.body2">@($"{checklists.CompletionRatePercent:0}%")</MudText>
                        </MudProgressCircular>
                        <div>
                            <MudText Typo="Typo.body2">Всего: @checklists.TotalActive</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Success">Завершено: @checklists.Completed</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Primary">В процессе: @checklists.InProgress</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4 rounded-lg stat-card h-100" Elevation="0">
                    <MudText Typo="Typo.subtitle2" Class="mb-3 d-flex align-center gap-1">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" /> Документы
                    </MudText>
                    <MudText Typo="Typo.h4" Class="mb-2">@documents.Total</MudText>
                    <div class="d-flex flex-wrap gap-1 mb-2">
                        @foreach (var (status, count) in documents.ByStatus)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@status: @count</MudChip>
                        }
                    </div>
                    <MudText Typo="Typo.caption" Class="text-muted">
                        Изменено за 7 дней: @documents.EditedLast7Days
                    </MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    };

    private RenderFragment RenderActivity(
        List<ChecklistActivitySummaryDto> checklists,
        List<DocumentActivitySummaryDto> documents,
        bool showOwner) => __builder =>
    {
        <MudGrid Class="mb-6">
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h6" Class="mb-2">Недавние чек-листы</MudText>
                @if (!checklists.Any())
                {
                    <MudText Typo="Typo.body2" Class="text-muted">Пока нет активности</MudText>
                }
                else
                {
                    <MudStack Spacing="2">
                        @foreach (var c in checklists)
                        {
                            <MudPaper Class="pa-3 rounded-lg activity-row" Elevation="0"
                                      @onclick="@(() => NavigationManager.NavigateTo($"/checklists/active/{c.Id}"))">
                                <div class="d-flex justify-space-between align-center">
                                    <MudText Typo="Typo.body1">@c.ChecklistTitle</MudText>
                                    <MudText Typo="Typo.caption">@($"{c.ProgressPercent:0}%")</MudText>
                                </div>
                                <MudProgressLinear Value="@c.ProgressPercent" Class="mt-1" Size="Size.Small"/>
                                @if (showOwner && !string.IsNullOrWhiteSpace(c.OwnerName))
                                {
                                    <MudText Typo="Typo.caption" Class="text-muted mt-1">@c.OwnerName</MudText>
                                }
                            </MudPaper>
                        }
                    </MudStack>
                }
            </MudItem>

            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h6" Class="mb-2">Недавние документы</MudText>
                @if (!documents.Any())
                {
                    <MudText Typo="Typo.body2" Class="text-muted">Пока нет активности</MudText>
                }
                else
                {
                    <MudStack Spacing="2">
                        @foreach (var d in documents)
                        {
                            <MudPaper Class="pa-3 rounded-lg activity-row" Elevation="0">
                                <div class="d-flex justify-space-between align-center">
                                    <MudText Typo="Typo.body1">@d.Title</MudText>
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@d.Status</MudChip>
                                </div>
                                <MudText Typo="Typo.caption" Class="text-muted">
                                    @d.UpdatedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                    @(showOwner && !string.IsNullOrWhiteSpace(d.OwnerName) ? $" · {d.OwnerName}" : "")
                                </MudText>
                            </MudPaper>
                        }
                    </MudStack>
                }
            </MudItem>
        </MudGrid>
    };

    private async Task LoadActivity()
    {
        if (_currentUserId is null) return;
        _isActivityLoading = true;
        StateHasChanged();

        _activity = await DashboardService.GetActivityAsync(_currentUserId.Value, organizationScope: _scope == DashboardScope.Organization);
        _heatmapWeeks = BuildHeatmapWeeks(_activity.HeatmapDays);

        _isActivityLoading = false;
        StateHasChanged();
    }

    private async Task SetScope(DashboardScope scope)
    {
        if (_scope == scope) return;
        _scope = scope;
        await LoadActivity(); 
    }

    private static List<List<ActivityHeatmapDayDto?>> BuildHeatmapWeeks(List<ActivityHeatmapDayDto> days)
    {
        if (!days.Any()) return new();

        var cells = new List<ActivityHeatmapDayDto?>();
        var startPad = (int)days.First().Date.DayOfWeek; 
        for (int i = 0; i < startPad; i++) cells.Add(null);
        cells.AddRange(days);
        while (cells.Count % 7 != 0) cells.Add(null);

        var weeks = new List<List<ActivityHeatmapDayDto?>>();
        for (int i = 0; i < cells.Count; i += 7)
            weeks.Add(cells.Skip(i).Take(7).ToList());
        return weeks;
    }

    private static string GetHeatmapLevelClass(int count) => count switch
    {
        0 => "heatmap-level-0",
        <= 2 => "heatmap-level-1",
        <= 4 => "heatmap-level-2",
        <= 7 => "heatmap-level-3",
        _ => "heatmap-level-4"
    };

    private static string GetHeatmapTooltip(ActivityHeatmapDayDto day) =>
        $"{day.Date:dd.MM.yyyy}: {day.Count} событий";

    private static Color GetEventColor(ActivityEventType type) => type switch
    {
        ActivityEventType.ChecklistStarted => Color.Primary,
        ActivityEventType.ChecklistItemCompleted => Color.Success,
        ActivityEventType.ChecklistItemUpdated => Color.Info,
        ActivityEventType.DocumentCreated => Color.Secondary,
        ActivityEventType.DocumentVersionSaved => Color.Tertiary,
        _ => Color.Default
    };

    private static string GetEventIcon(ActivityEventType type) => type switch
    {
        ActivityEventType.ChecklistStarted => Icons.Material.Filled.PlayArrow,
        ActivityEventType.ChecklistItemCompleted => Icons.Material.Filled.CheckCircle,
        ActivityEventType.ChecklistItemUpdated => Icons.Material.Filled.Edit,
        ActivityEventType.DocumentCreated => Icons.Material.Filled.NoteAdd,
        ActivityEventType.DocumentVersionSaved => Icons.Material.Filled.Save,
        _ => Icons.Material.Filled.Circle
    };

    private void NavigateIfPossible(string? url)
    {
        if (!string.IsNullOrWhiteSpace(url))
            NavigationManager.NavigateTo(url);
    }
}
