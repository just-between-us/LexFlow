@page "/profile"
@attribute [Authorize]
@using Lex.Domain.Entities
@using Lex.Domain.Enums
@using Lex.Components.Auth
@using Lex.Components.Utils
@using Lex.Domain.DTOs
@using Lex.Infrastructure.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject UserManager<User> UserManager
@inject UserContext UserContext
@inject ISnackbar Snackbar
@inject AppDbContext DbContext

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-8">
    <MudText Typo="Typo.h3" Class="mb-2">Мой профиль</MudText>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-8" />
    }
    else if (_currentUser == null)
    {
        <MudAlert Severity="Severity.Error">Ошибка загрузки данных пользователя.</MudAlert>
    }
    else
    {
        <!-- Карточка с основной информацией -->
        <MudCard Elevation="1" Class="mb-6">
            <MudCardContent>
                <div class="d-flex align-center gap-4 mb-4">
                    <MudAvatar Class="avatar-large">
                        <MudIcon Icon="@Icons.Material.Filled.Person" />
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.h5">@_currentUser.GetFullName()</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@_currentUser.Email</MudText>
                        Тип активности: 
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="mt-1">
                            @DisplayHelper.GetActivityTypeDisplay(_currentUser.ActivityType)
                        </MudChip>
                    </div>
                </div>

                @if (_currentUser.Profile == null)
                {
                    <MudAlert Severity="Severity.Warning" Class="mb-3">
                        Профиль ещё не создан. Дополните информацию о себе.
                    </MudAlert>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateProfile">
                        Создать профиль
                    </MudButton>
                }
                else
                {
                    <div class="profile-details">
                        <MudText Typo="Typo.body1"><strong>Должность:</strong> @(_currentUser.Profile.JobTitle ?? "—")</MudText>
                        <MudText Typo="Typo.body1"><strong>Компания:</strong> @(_currentUser.Profile.CompanyName ?? "—")</MudText>
                        <MudText Typo="Typo.body1"><strong>Регион:</strong> @(_currentUser.Profile.Region ?? "—")</MudText>
                        <MudText Typo="Typo.body1"><strong>Дата рождения:</strong> @(_currentUser.Profile.BirthDate?.ToString("dd.MM.yyyy") ?? "—")</MudText>
                    </div>
                }
            </MudCardContent>
        </MudCard>

        <!-- Форма редактирования -->
        <MudCard Elevation="1">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Редактировать профиль</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <EditForm Model="@_profileEditModel" OnValidSubmit="SaveChanges">
                    <DataAnnotationsValidator />
                    <div class="d-flex flex-column gap-3">
                        <!-- Поля User -->
                        <MudTextField @bind-Value="_profileEditModel.FirstName" Label="Имя" T="string" />
                        <MudTextField @bind-Value="_profileEditModel.LastName" Label="Фамилия" T="string" />
                        <MudSelect @bind-Value="_profileEditModel.ActivityType" Label="Тип деятельности" T="UserActivityType">
                            @foreach (UserActivityType type in Enum.GetValues(typeof(UserActivityType)))
                            {
                                <MudSelectItem Value="type">@DisplayHelper.GetActivityTypeDisplay(type)</MudSelectItem>
                            }
                        </MudSelect>

                        <MudDivider />

                        <!-- Поля UserProfile -->
                        <MudTextField @bind-Value="_profileEditModel.JobTitle" Label="Должность" T="string" />
                        <MudTextField @bind-Value="_profileEditModel.CompanyName" Label="Компания" T="string" />
                        <MudTextField @bind-Value="_profileEditModel.Region" Label="Регион" T="string" />
                        <MudDatePicker @bind-Value="_profileEditModel.BirthDate" Label="Дата рождения" />
                    </div>
                </EditForm>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveChanges">Сохранить</MudButton>
            </MudCardActions>
        </MudCard>
    }
</MudContainer>

@code {
    private User? _currentUser;
    private bool _isLoading = true;
    private ProfileEditModel _profileEditModel = new();

    protected override async Task OnInitializedAsync()
    {
        var userId = UserContext.CurrentUser?.UserId;
        if (string.IsNullOrEmpty(userId))
        {
            _isLoading = false;
            return;
        }

        if (!Guid.TryParse(userId, out var guid))
        {
            _isLoading = false;
            return;
        }

        _currentUser = await UserManager.Users
            .Include(u => u.Profile)
            .FirstOrDefaultAsync(u => u.Id == guid);

        if (_currentUser != null)
        {
            _profileEditModel = new ProfileEditModel
            {
                FirstName = _currentUser.FirstName,
                LastName = _currentUser.LastName,
                ActivityType = _currentUser.ActivityType,
                JobTitle = _currentUser.Profile?.JobTitle,
                CompanyName = _currentUser.Profile?.CompanyName,
                Region = _currentUser.Profile?.Region,
                BirthDate = _currentUser.Profile?.BirthDate
            };
        }

        _isLoading = false;
    }

    private async Task CreateProfile()
    {
        if (_currentUser == null) return;

        _currentUser.Profile = new UserProfile
        {
            Id = Guid.NewGuid(),
            UserId = _currentUser.Id,
            CreatedAtUtc = DateTime.UtcNow
        };

        await UserManager.UpdateAsync(_currentUser);
        Snackbar.Add("Профиль создан. Теперь вы можете заполнить детали.", Severity.Success);

        // Обновляем UI
        _currentUser = await UserManager.Users
            .Include(u => u.Profile)
            .FirstOrDefaultAsync(u => u.Id == _currentUser.Id);
        StateHasChanged();
    }

    private async Task SaveChanges()
    {
        if (_currentUser == null) return;

        // Обновляем User
        _currentUser.FirstName = _profileEditModel.FirstName;
        _currentUser.LastName = _profileEditModel.LastName;
        _currentUser.ActivityType = _profileEditModel.ActivityType;

        // Обновляем UserProfile (если есть)
        if (_currentUser.Profile != null)
        {
            _currentUser.Profile.JobTitle = _profileEditModel.JobTitle;
            _currentUser.Profile.CompanyName = _profileEditModel.CompanyName;
            _currentUser.Profile.Region = _profileEditModel.Region;
            _currentUser.Profile.BirthDate = _profileEditModel.BirthDate;
            _currentUser.Profile.UpdatedAtUtc = DateTime.UtcNow;
        }

        await UserManager.UpdateAsync(_currentUser);
        if (_currentUser.Profile != null)
            await DbContext.SaveChangesAsync(); // т.к. профиль — обычная сущность

        Snackbar.Add("Профиль обновлён", Severity.Success);
        StateHasChanged();
    }
}