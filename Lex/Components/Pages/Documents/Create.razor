@page "/documents/create"
@attribute [Authorize]
@using Lex.Domain.Entities
@using Lex.Domain.Enums
@using Lex.Components.Auth
@using Lex.Components.Utils
@using Lex.Domain.Interfaces
@using Microsoft.AspNetCore.Authorization
@using Markdig
@inject IDocumentHelperService DocumentHelperService
@inject IDocumentService DocumentService
@inject UserContext UserContext
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-8">
    @if (_isInitializing)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (_currentUserId == null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">
            Ошибка авторизации. Пожалуйста, войдите в систему.
        </MudAlert>
    }
    else
    {
        <MudText Typo="Typo.h4" Class="mb-4">Создание документа на основе шаблона</MudText>

        <EditForm Model="@_document" OnValidSubmit="SaveDocumentAsync">
            <DataAnnotationsValidator />
            <MudGrid>
                <!-- Левая колонка: Редактор -->
                <MudItem xs="12" md="6">
                    <MudCard Elevation="1" Class="mb-4">
                        <MudCardContent>
                            <MudTextField @bind-Value="_document.Title"
                                          Label="Название документа"
                                          Required="true"
                                          For="@(() => _document.Title)"
                                          T="string" Class="mb-3" />

                            <MudTextField @bind-Value="_document.Description"
                                          Label="Описание"
                                          Lines="2"
                                          T="string" Class="mb-3" />

                            <MudSelect @bind-Value="_document.Type"
                                       Label="Тип документа"
                                       T="DocumentType" Class="mb-3">
                                @foreach (DocumentType type in Enum.GetValues(typeof(DocumentType)))
                                {
                                    <MudSelectItem T="DocumentType" Value="type">
                                        @DocumentHelperService.GetTypeDisplayName(type)
                                    </MudSelectItem>
                                }
                            </MudSelect>

                            <MudSelect @bind-Value="_document.Privacy"
                                       Label="Уровень доступа"
                                       T="DocumentPrivacy" Class="mb-3">
                                @foreach (DocumentPrivacy privacy in Enum.GetValues(typeof(DocumentPrivacy)))
                                {
                                    <MudSelectItem T="DocumentPrivacy" Value="privacy">
                                        @DocumentHelperService.GetPrivacyDisplayName(privacy)
                                    </MudSelectItem>
                                }
                            </MudSelect>

                            <MudTextField @bind-Value="_document.CurrentContent"
                                          Label="Содержимое (Markdown)"
                                          Lines="15"
                                          T="string"
                                          Immediate="true"
                                          OnKeyUp="UpdatePreview" />

                            <div class="d-flex align-center gap-2 mt-2">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Статус: @DocumentHelperService.GetStatusDisplayName(_document.Status)
                                </MudText>
                                <MudSwitch @bind-Value="_archiveImmediately" Label="Сразу в архив" Color="Color.Warning" />
                            </div>
                        </MudCardContent>

                        <MudCardActions>
                            <MudTooltip Text="Создать документ и первую версию" Arrow="true">
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           ButtonType="ButtonType.Submit"
                                           StartIcon="@Icons.Material.Filled.Save"
                                           Disabled="@_isSaving">
                                    @(_isSaving ? "Сохранение..." : "Сохранить документ")
                                </MudButton>
                            </MudTooltip>

                            <MudTooltip Text="Функция экспорта появится позже" Arrow="true">
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Secondary"
                                           OnClick="ExportPlaceholder"
                                           StartIcon="@Icons.Material.Filled.FileDownload">
                                    Экспорт
                                </MudButton>
                            </MudTooltip>

                            <MudTooltip Text="Черновик будет потерян, вы не сможете вернуться к редактированию" Arrow="true">
                                <MudButton Variant="Variant.Text"
                                           OnClick="Cancel">
                                    Отмена
                                </MudButton>
                            </MudTooltip>
                        </MudCardActions>
                    </MudCard>
                </MudItem>

                <!-- Правая колонка: Предпросмотр Markdown -->
                <MudItem xs="12" md="6">
                    <MudCard Elevation="1" Class="h-100">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Предпросмотр</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent Class="markdown-preview">
                            @if (string.IsNullOrWhiteSpace(_document.CurrentContent))
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    Начните вводить текст в редакторе слева...
                                </MudText>
                            }
                            else
                            {
                                @((MarkupString)RenderMarkdown(_document.CurrentContent))
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </EditForm>
    }
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "templateId")]
    public Guid? TemplateId { get; set; }

    private Document _document = new();
    private bool _isInitializing = true;
    private bool _isSaving;
    private bool _archiveImmediately;
    private Guid? _currentUserId;

    // Генератор Markdown (статический, чтобы не создавать на каждое нажатие)
    private static readonly MarkdownPipeline Pipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    protected override async Task OnInitializedAsync()
    {
        _currentUserId = Guid.TryParse(UserContext.CurrentUser?.UserId, out var userId) ? userId : null;
        
        if (_currentUserId == null || !UserContext.IsAuthenticated)
        {
            Snackbar.Add("Для создания документа необходимо авторизоваться", Severity.Error);
            _isInitializing = false;
            return;
        }

        if (!TemplateId.HasValue)
        {
            Snackbar.Add("Не указан шаблон для создания документа", Severity.Warning);
            Navigation.NavigateTo("/templates");
            return;
        }

        try
        {
            var templateModel = await DocumentService.GetTemplateForEditingAsync(TemplateId.Value);
            if (templateModel != null)
            {
                _document = new Document
                {
                    Title = templateModel.Title,
                    Description = templateModel.Description,
                    Type = templateModel.Type,
                    CurrentContent = templateModel.CurrentContent,
                    TemplateId = templateModel.Id,
                    Status = DocumentStatus.Draft,
                    Privacy = DocumentPrivacy.Private, // значение по умолчанию
                    CreatedByUserId = _currentUserId.Value
                };
            }
            else
            {
                Snackbar.Add("Шаблон не найден", Severity.Warning);
                Navigation.NavigateTo("/templates");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка загрузки шаблона: {ex.Message}", Severity.Error);
            Navigation.NavigateTo("/templates");
        }
        finally
        {
            _isInitializing = false;
        }
    }

    private async Task SaveDocumentAsync()
    {
        if (_currentUserId == null)
        {
            Snackbar.Add("Ошибка авторизации", Severity.Error);
            return;
        }

        if (string.IsNullOrWhiteSpace(_document.Title))
        {
            Snackbar.Add("Название документа обязательно", Severity.Warning);
            return;
        }

        _isSaving = true;
        StateHasChanged();

        try
        {
            if (!TemplateId.HasValue)
            {
                Snackbar.Add("Не указан шаблон", Severity.Error);
                return;
            }

            await DocumentService.CreateDocumentFromTemplateAsync(
                TemplateId.Value,
                _currentUserId.Value,
                _document.Privacy,
                _archiveImmediately);

            Snackbar.Add("Документ успешно создан", Severity.Success);
            await Task.Delay(600);
            Navigation.NavigateTo("/documents/my");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка при сохранении: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private void UpdatePreview(KeyboardEventArgs e) => StateHasChanged(); // для немедленного обновления предпросмотра при вводе

    private static string RenderMarkdown(string markdown) =>
        Markdown.ToHtml(markdown ?? string.Empty, Pipeline);

    private void ExportPlaceholder()
    {
        Snackbar.Add("Функция экспорта будет реализована позже", Severity.Info);
    }

    private void Cancel()
    {
        Navigation.NavigateTo(TemplateId.HasValue ? $"/templates/view/{TemplateId}" : "/templates");
    }
}