@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]
@using Lex.Domain.DTOs
@using Lex.Domain.Entities
@using Lex.Domain.Interfaces
@using Microsoft.AspNetCore.Authorization
@inject IUserManagementService UserService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Управление пользователями</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-8">
    <MudText Typo="Typo.h3" Class="mb-2">Пользователи системы</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        Управление учётными записями, активностью и ролями пользователей
    </MudText>

    <MudPaper Class="pa-4 mb-6" Elevation="0">
        <MudGrid>
            <MudItem xs="12" sm="6" md="4">
                <MudTextField @bind-Value="_searchTerm" 
                              Placeholder="Поиск по email, имени..."
                              Immediate="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              T="string"
                              OnKeyUp="OnSearchEnter"/>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect @bind-Value="_filterActive" Label="Статус" T="bool?" Variant="Variant.Outlined">
                    <MudSelectItem T="bool?" Value="@((bool?)null)">Все</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@((bool?)true)">Активные</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@((bool?)false)">Неактивные</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect @bind-Value="_filterLocked" Label="Блокировка" T="bool?" Variant="Variant.Outlined">
                    <MudSelectItem T="bool?" Value="@((bool?)null)">Все</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@((bool?)true)">Заблокированные</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@((bool?)false)">Не заблокированные</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@LoadUsers" FullWidth>
                    Применить
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (_users == null)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-8" />
    }
    else if (!_users.Any())
    {
        <MudPaper Class="pa-8 text-center" Elevation="0">
            <MudIcon Icon="@Icons.Material.Filled.PeopleOutline" Class="mb-4" Style="font-size:64px;color:var(--mud-palette-text-disabled)"/>
            <MudText Typo="Typo.h6">Пользователи не найдены</MudText>
        </MudPaper>
    }
    else
    {
        <MudTable Items="_users" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="1">
            <HeaderContent>
                <MudTh>Пользователь</MudTh>
                <MudTh>Email</MudTh>
                <MudTh>Статус</MudTh>
                <MudTh>Роли</MudTh>
                <MudTh>Дата регистрации</MudTh>
                <MudTh>Действия</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Пользователь">
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Size="Size.Small"/>
                        @context.User.GetFullName()
                    </div>
                </MudTd>
                <MudTd DataLabel="Email">@context.User.Email</MudTd>
                <MudTd DataLabel="Статус">
                    <MudChip T="string" Size="Size.Small" Color="@(context.User.IsActive ? Color.Success : Color.Error)">
                        @(context.User.IsActive ? "Активен" : "Неактивен")
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Роли">
                    @string.Join(", ", context.Roles)
                </MudTd>
                <MudTd DataLabel="Дата регистрации">
                    @context.User.CreatedAtUtc.ToString("dd.MM.yyyy HH:mm")
                </MudTd>
                <MudTd DataLabel="Действия">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenUserEditDialog(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Lock" Size="Size.Small" OnClick="@(() => ToggleUserLock(context.User))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteUser(context.User))" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
            </PagerContent>
        </MudTable>
    }
</MudContainer>

<MudDialog @bind-Visible="_editDialogVisible" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Редактирование пользователя: @_editUser?.GetFullName()</MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="pa-0">
            <MudTextField @bind-Value="_editFirstName" Label="Имя" T="string" Class="mb-3"/>
            <MudTextField @bind-Value="_editLastName" Label="Фамилия" T="string" Class="mb-3"/>
            <MudSwitch @bind-Value="_editIsActive" Label="Активен" Color="Color.Success" Class="mb-3"/>
            <MudText Typo="Typo.subtitle2" Class="mb-2">Роли:</MudText>
            @foreach (var item in _editRolesList)
            {
                <MudCheckBox @bind-Value="item.Selected" Label="@item.Name" Color="Color.Primary" Class="ml-2" />
            }
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _editDialogVisible = false)">Отмена</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@SaveUserChanges">Сохранить</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<UserWithRoles>? _users;
    private string _searchTerm = string.Empty;
    private bool? _filterActive;
    private bool? _filterLocked;
    private bool _editDialogVisible = false;
    private User? _editUser;
    private string _editFirstName = string.Empty;
    private string _editLastName = string.Empty;
    private bool _editIsActive;
    private Dictionary<string, bool> _editRoles = new();
    private List<string> _allRoles = new();
    private DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
    private List<RoleSelection> _editRolesList = new();

    public class RoleSelection
    {
        public string Name { get; set; }
        public bool Selected { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        _allRoles = await UserService.GetAllRoleNamesAsync();
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        _users = await UserService.GetUsersAsync(_searchTerm, _filterActive, _filterLocked);
    }

    private async Task OnSearchEnter(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoadUsers();
    }

    private async Task ToggleUserLock(User user)
    {
        await UserService.ToggleUserLockAsync(user);
        Snackbar.Add(await IsLockedOutAsync(user) ? "Заблокирован" : "Разблокирован", Severity.Success);
        await LoadUsers();
    }

    private async Task DeleteUser(User user)
    {
        var result = await DialogService.ShowMessageBox("Удаление пользователя",
            $"Деактивировать {user.Email}?",
            yesText: "Деактивировать", cancelText: "Отмена");
        if (result == true)
        {
            await UserService.SoftDeleteUserAsync(user);
            Snackbar.Add("Пользователь деактивирован", Severity.Warning);
            await LoadUsers();
        }
    }

    private async Task OpenUserEditDialog(UserWithRoles userWithRoles)
    {
        var user = userWithRoles.User;
        _editUser = user;
        _editFirstName = user.FirstName ?? "";
        _editLastName = user.LastName ?? "";
        _editIsActive = user.IsActive;
        _editRolesList = _allRoles.Select(r => new RoleSelection 
        { 
            Name = r, 
            Selected = userWithRoles.Roles.Contains(r) 
        }).ToList();
        _editRoles = _allRoles.ToDictionary(r => r, r => userWithRoles.Roles.Contains(r));
        _editDialogVisible = true;
    }

    private async Task SaveUserChanges()
    {
        if (_editUser == null) return;
        await UserService.UpdateUserAsync(_editUser, _editFirstName, _editLastName, _editIsActive, _editRoles);
        _editDialogVisible = false;
        Snackbar.Add("Данные обновлены", Severity.Success);
        await LoadUsers();
    }

    private async Task<bool> IsLockedOutAsync(User user)
    {
        var freshUser = await UserService.GetUsersAsync(null, null, null);
        return freshUser.FirstOrDefault(u => u.User.Id == user.Id)?.User.LockoutEnd != null;
    }
}