@page "/checklists/start"
@attribute [Authorize]
@using Lex.Components.Auth
@using Lex.Domain.Interfaces
@using Microsoft.AspNetCore.Authorization
@inject IActiveChecklistService ActiveChecklistService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject UserContext UserContext

<PageTitle>Запуск чек-листа</PageTitle>

<div class="d-flex flex-column align-center justify-center" style="min-height: 60vh;">
    @if (_isProcessing)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.body1" Class="mt-4">@_statusMessage</MudText>
    }
    else if (_errorMessage is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-3">@_errorMessage</MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="@(() => NavigationManager.NavigateTo("/checklists/templates"))">
            Вернуться в каталог
        </MudButton>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "templateId")]
    public Guid? TemplateId { get; set; }

    private bool _isProcessing = true;
    private string _statusMessage = "Загрузка...";
    private string? _errorMessage;
    private Guid _currentUserId;
    
    
    protected override async Task OnInitializedAsync()
    {
        _currentUserId = Guid.TryParse(UserContext.CurrentUser?.UserId, out var uid) ? uid : Guid.Empty;
        
        if (!UserContext.IsAuthenticated)
        {
            Snackbar.Add("Для создания документа необходимо авторизоваться", Severity.Error);
            return;
        }
        
        if (TemplateId is null || TemplateId == Guid.Empty)
        {
            _errorMessage = "Не указан чек-лист для запуска.";
            _isProcessing = false;
            return;
        }
        
        await ResolveActiveChecklistAsync(TemplateId.Value);
    }

    private async Task ResolveActiveChecklistAsync(Guid templateId)
    {
        try
        {
            _statusMessage = "Проверяем прогресс...";
            StateHasChanged();
                var existing = await ActiveChecklistService.GetActiveForUserAsync(_currentUserId, templateId);

                if (existing is not null && !existing.IsDeleted)
                {
                    NavigateToActive(existing.Id);
                    return;
                }

                if (existing is not null && existing.IsDeleted)
                {
                    var shouldRestore = await DialogService.ShowMessageBox(
                        "Найден удалённый прогресс",
                        $"Вы уже проходили чек-лист «{existing.ChecklistTitle}», но он был удалён. Восстановить прогресс или начать заново?",
                        yesText: "Восстановить", noText: "Начать заново");

                    if (shouldRestore == true)
                    {
                        var restored = await ActiveChecklistService.RestoreAsync(existing.Id);
                        Snackbar.Add("Прогресс восстановлен", Severity.Success);
                        NavigateToActive(restored.Id);
                        return;
                    }
                }
                _statusMessage = "Запускаем чек-лист...";
                StateHasChanged();
                
                var created = await ActiveChecklistService.StartNewAsync(_currentUserId, templateId);
                NavigateToActive(created.Id);
        }
        catch (InvalidOperationException ex)
        {
            _errorMessage = ex.Message;
            _isProcessing = false;
        }
        catch (Exception)
        {
            _errorMessage = "Не удалось запустить чек-лист. Попробуйте ещё раз.";
            _isProcessing = false;
        }
    }

    private void NavigateToActive(Guid activeChecklistId)
        => NavigationManager.NavigateTo($"/checklists/active/{activeChecklistId}", replace: true);
}