@page "/checklists/my"
@attribute [Authorize]
@using Lex.Domain.Entities
@using Lex.Infrastructure.Repositories
@using Lex.Components.Auth
@using Microsoft.AspNetCore.Authorization
@inject ActiveChecklistRepository ActiveRepo
@inject UserContext UserContext
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Navigation

<div class="py-4">
    <PageTitle>Мои активные чек-листы</PageTitle>
</div>

    <MudText Typo="Typo.h4" Class="mb-2">Мои активные чек-листы</MudText>
    <MudText Typo="Typo.body2" Class="text-muted">
        Продолжайте прохождение или просматривайте завершённые
    </MudText>

    @if (!_isAuthorized)
    {
        <MudAlert Severity="Severity.Error">Требуется авторизация.</MudAlert>
    }
    else if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-8" />
    }
    else if (!_activeChecklists.Any())
    {
        <MudPaper Class="pa-8 text-center" Elevation="0">
            <MudIcon Icon="@Icons.Material.Filled.Checklist" Class="mb-4" Style="font-size:64px;color:var(--mud-palette-text-disabled)"/>
            <MudText Typo="Typo.h6">Нет активных чек-листов</MudText>
            <MudText Color="Color.Secondary" Class="mb-3">Начните новый из каталога</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/checklists/templates">
                Перейти к каталогу
            </MudButton>
        </MudPaper>
    }
    else
    {
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" Class="mb-4"
                 @bind-ActivePanelIndex="_activeTabIndex">
            <MudTabPanel Text="@($"В процессе ({_inProgressCount})")" />
            <MudTabPanel Text="@($"Завершённые ({_completedCount})")" />
            <MudTabPanel Text="@($"Все ({_activeChecklists.Count})")" />
        </MudTabs>

        @if (!_filteredChecklists.Any())
        {
            <MudPaper Class="pa-6 text-center" Elevation="0">
                <MudText Color="Color.Secondary">Нет чек-листов в этой категории</MudText>
            </MudPaper>
        }
        else
        {
            <MudGrid>
                @foreach (var active in _filteredChecklists)
                {
                    var progress = GetProgress(active);
                    var isCompleted = progress >= 100;

                    <MudItem xs="12" sm="6" lg="4">
                        <MudCard Elevation="1" Class="active-checklist-card h-100 d-flex flex-column">
                            <MudCardContent Class="flex-grow-1">
                                <div class="d-flex justify-space-between align-start mb-2">
                                    <MudText Typo="Typo.h6" Class="text-truncate mr-2">
                                        @active.Checklist?.Title
                                    </MudText>
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(isCompleted ? Color.Success : Color.Primary)"
                                             Variant="Variant.Text">
                                        @(isCompleted ? "Завершён" : "В процессе")
                                    </MudChip>
                                </div>

                                <div class="d-flex align-center gap-2 mb-3">
                                    <MudProgressLinear Value="@progress"
                                                       Color="@(isCompleted ? Color.Success : Color.Primary)"
                                                       Class="flex-grow-1" />
                                    <MudText Typo="Typo.body2" Class="flex-shrink-0">@progress.ToString("F0")%</MudText>
                                </div>

                                <div class="d-flex flex-wrap gap-2 mb-2">
                                    <MudText Class="d-flex align-center" Typo="Typo.caption" Color="Color.Secondary">
                                        <MudIcon Icon="@Icons.Material.Filled.ListAlt" Size="Size.Small" Class="mr-1" />
                                        <MudText Typo="Typo.body2">@active.Items.Count пунктов</MudText>
                                    </MudText>
                                    <MudText Class="d-flex align-center" Typo="Typo.caption" Color="Color.Secondary">
                                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />
                                        <MudText Typo="Typo.body2">@((active.UpdatedAtUtc ?? active.CreatedAtUtc).ToString("dd.MM.yyyy"))</MudText>
                                    </MudText>
                                </div>

                                @if (active.ClientOrganization != null)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                                        @active.ClientOrganization.Name
                                    </MudChip>
                                }
                            </MudCardContent>

                            <MudCardActions Class="border-top pa-2 gap-1">
                                <MudButton StartIcon="@Icons.Material.Filled.PlayArrow"
                                           Color="Color.Primary"
                                           Variant="Variant.Filled"
                                           Size="Size.Small"
                                           OnClick="@(() => ContinueChecklist(active.Id))"
                                           FullWidth>
                                    @(isCompleted ? "Просмотр" : "Продолжить")
                                </MudButton>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => DeleteChecklist(active))" />
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    }

@code {
    private List<ActiveChecklist> _activeChecklists = new();
    private bool _isLoading = true;
    private bool _isAuthorized;
    private Guid? _currentUserId;
    private int _activeTabIndex;

    private int _inProgressCount => _activeChecklists.Count(a => GetProgress(a) < 100);
    private int _completedCount => _activeChecklists.Count(a => GetProgress(a) >= 100);

    private IEnumerable<ActiveChecklist> _filteredChecklists => _activeTabIndex switch
    {
        0 => _activeChecklists.Where(a => GetProgress(a) < 100),
        1 => _activeChecklists.Where(a => GetProgress(a) >= 100),
        _ => _activeChecklists
    };

    protected override async Task OnInitializedAsync()
    {
        _currentUserId = Guid.TryParse(UserContext.CurrentUser?.UserId, out var uid) ? uid : null;
        _isAuthorized = _currentUserId.HasValue;
        if (_isAuthorized)
            await LoadChecklists();
        else
            _isLoading = false;
    }

    private async Task LoadChecklists()
    {
        try
        {
            _activeChecklists = (await ActiveRepo.GetUserActiveChecklistsAsync(_currentUserId!.Value)).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка загрузки: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private static double GetProgress(ActiveChecklist active) =>
        active.Items.Any()
            ? Math.Round((double)active.Items.Count(i => i.IsCompleted) / active.Items.Count * 100, 0)
            : 0;

    private void ContinueChecklist(Guid activeChecklistId)
    {
        Navigation.NavigateTo($"/checklists/active/{activeChecklistId}");
    }

    private async Task DeleteChecklist(ActiveChecklist active)
    {
        var result = await DialogService.ShowMessageBox("Удаление", "Удалить этот чек-лист? Прогресс будет потерян.",
            yesText: "Удалить", cancelText: "Отмена");
        if (result != true) return;

        active.IsDeleted = true;
        active.UpdatedAtUtc = DateTime.UtcNow;
        await ActiveRepo.UpdateAsync(active);

        Snackbar.Add("Чек-лист удалён", Severity.Warning);
        _activeChecklists.Remove(active);
    }
}